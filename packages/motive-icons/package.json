{
  "name": "rex-motive",
  "version": "0.1.0",
  "description": "Beautiful animated icons for modern React interfaces. Copy, customize, and ship.",
  "keywords": ["react", "icons", "animated-icons", "framer-motion", "lucide", "phosphor", "svg"],
  "license": "MIT",
  "author": "Ram Shukla",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && cp src/index.d.ts dist/index.d.ts",
    "prepack": "yarn build"
  },
  "peerDependencies": {
    "framer-motion": ">=10.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "esbuild": "0.24.0",
    "typescript": "5.6.3"
  }
}
